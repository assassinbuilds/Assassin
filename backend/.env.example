# =============================================================================
# TechAssassin Backend - Live Environment Configuration
# =============================================================================
# 
# IMPORTANT: 
# - Copy this file to .env.local for local development
# - Use the Supabase Transaction Pooler URL for DATABASE_URL
# - Ensure Supabase project is active and migrations are applied
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Supabase Direct/Pooler)
# -----------------------------------------------------------------------------
# Get connection details from Supabase Dashboard > Settings > Database
#
# Recommended: Use Transaction Pooler (Port 6543) for serverless environments
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true
#
# Alternative: Direct Connection (Port 5432)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[DB-HOST]:5432/postgres
#
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Individual settings (Optional, used if DATABASE_URL is not provided)
DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_password

# -----------------------------------------------------------------------------
# Supabase Authentication & Project Settings
# -----------------------------------------------------------------------------
# Get these values from: Supabase Dashboard > Settings > API
#
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Development keys start with pk_test_ / sk_test_.
# Production keys start with pk_live_ / sk_live_.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# -----------------------------------------------------------------------------
# Email Configuration (Resend)
# -----------------------------------------------------------------------------
# Get your API key from: Resend Dashboard > API Keys
#
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@techassassin.com
RESEND_FROM_NAME=Tech Assassin

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_RESEND_COOLDOWN_SECONDS=60

# Email templates
OTP_PASSWORD_RESET_TEMPLATE=password-reset
OTP_LOGIN_VERIFICATION_TEMPLATE=login-verification
OTP_EMAIL_VERIFICATION_TEMPLATE=email-verification

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Base URL of your application
#
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT Configuration (Minimum 32 characters)
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# SMTP CONFIGURATION (GMAIL/FALLBACK)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Tech Assassin
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# MURF AI CONFIGURATION
# -----------------------------------------------------------------------------
MURF_API_KEY=your_murf_api_key
MURF_API_ID=your_murf_api_id
