# Kiro files
.kiro/

# =============================================================================
# DOCUMENTATION
# Ignore stray Markdown notes by default, but keep project docs/content tracked.
# =============================================================================
*.md
!README.md
!**/README.md
!SECURITY.md
!**/SECURITY.md
!CODE_OF_CONDUCT.md
!code_of_conduct.md
!CONTRIBUTING.md
!PROJECT_HANDOFF.md
!Docs/**/*.md
!docs/**/*.md
!content/**/*.md

# =============================================================================
# SQL FILES
# =============================================================================
*.sql
!backend/supabase/migrations/
!backend/supabase/migrations/**
!backend/supabase/migrations/*.sql

# Specific local SQL files to ignore
COMPLETE_DATABASE_SETUP.sql
FIX_MISSING_COLUMNS.sql
VERIFY_DATABASE.sql

# =============================================================================
# SUPABASE
# =============================================================================
backend/supabase/
**/supabase/
!backend/supabase/
!backend/supabase/migrations/
!backend/supabase/migrations/**
!backend/lib/supabase/
!backend/lib/supabase/**

# =============================================================================
