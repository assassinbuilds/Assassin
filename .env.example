# Root environment reference for Tech Assassin.
# Copy app-specific values into Client/.env.local or backend/.env.local.

# Public frontend values. These can be exposed by Vite.
VITE_API_URL=http://localhost:3001/api
VITE_APP_URL=http://localhost:3000
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Backend-only secrets. Never expose these in frontend VITE_ variables.
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
JWT_SECRET=replace_with_at_least_32_characters
RESEND_API_KEY=re_your_resend_api_key
SMTP_PASS=your_smtp_password
